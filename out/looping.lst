    68 				; =====================================================================
    69 				; CIO (Central I/O) constants
    70 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    71 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    72 				; of memory containing command, device, buffer address, and aux bytes.
    73 				; We use IOCB6 (base address $0360) for graphics.
    74 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    75 				; =====================================================================
    76 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    77 = 0342			ICCOM   = $0342     ; IOCB6 command register
    78 				                    ;   $03 = OPEN   (open a device)
    79 				                    ;   $0C = CLOSE  (close a device)
    80 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    81 				                    ;   for OPEN: points to device name string "S:"
    82 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    83 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    84 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    85 				                    ;   for OPEN: $0C = read/write access mode
    86 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    87 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    88
    89 				; =====================================================================
    90 				; Screen RAM pointer
    91 				; After CIO opens GR.8, the OS stores the address of screen RAM
    92 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    93 				; On our 800XL PAL system screen RAM ends up at $B060.
    94 				; =====================================================================
    95 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    96 				                    ; $59 automatically contains the high byte
    97
    98 				; =====================================================================
    99 				; Attract mode constants
   100 				; The Atari OS has an attract mode that kicks in after inactivity
   101 				; to prevent screen burn-in. It does this by desaturating all colors
   102 				; making everything appear as shades of grey/blue.
   103 				; We must continuously reset these in our main loop to keep colors!
   104 				; =====================================================================
   105 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
   106 				                    ; when it reaches a threshold attract mode activates
   107 				                    ; we keep writing 0 to prevent it from activating
   108 = 004E			ATRMSK  = $4E       ; attract mode color mask
   109 				                    ; OS ANDs all colors with this value
   110 				                    ; $FE strips hue leaving only luminance (grey/blue)
   111 				                    ; $FF = full color (no masking) — what we want
     2 				        icl 'routines.asm'
