   212 				        ; advance circX
   213 312D E6 9F		        inc circX
   214
   215 				        ; check sign of cerr
   216 312F A5 A2		        lda cerr_hi
   217 3131 30 19		        bmi update_negative     ; cerr < 0
   218
   219 				        ; positive path: cerr >= 0
   220 3133 C6 A0		        dec circY               ; circY = circY - 1
   221 3135 A5 9F		        lda circX
   222 3137 38			        sec
   223 3138 E5 A0		        sbc circY               ; A = circX - circY
   224 313A 0A			        asl                     ; A = 2*(circX-circY)
   225 313B 18			        clc
   226 313C 69 01		        adc #1                  ; A = 2*(circX-circY) + 1
   227 313E 18			        clc
   228 313F 65 A1		        adc cerr_lo
   229 3141 85 A1		        sta cerr_lo
   230 3143 A5 A2		        lda cerr_hi
   231 3145 69 00		        adc #0
   232 3147 85 A2		        sta cerr_hi
   233 3149 4C 5D 31		        jmp check_done          ; skip negative path
   234
   235 314C			update_negative:
   236 				        ; negative path: cerr < 0
   237 314C A5 9F		        lda circX
   238 314E 0A			        asl                     ; A = 2*circX
   239 314F 18			        clc
   240 3150 69 01		        adc #1                  ; A = 2*circX + 1
   241 3152 18			        clc
   242 3153 65 A1		        adc cerr_lo
   243 3155 85 A1		        sta cerr_lo
   244 3157 A5 A2		        lda cerr_hi
   245 3159 69 00		        adc #0
   246 315B 85 A2		        sta cerr_hi
   247 				                                ; fall through to check_done
   248
   249 315D			check_done:
   250 315D A5 9F		        lda circX
   251 315F C5 A0		        cmp circY
   252 3161 90 03		        bcc keep_going      ; circX < circY — short forward branch
   253 3163 F0 01		        beq keep_going      ; circX = circY — short forward branch
   254 3165 60			        rts                 ; circX > circY — done!
   255 3166			keep_going:
   256 3166 4C 15 30		        jmp circleloop      ; jump back — unlimited range
   257 				        .endp
