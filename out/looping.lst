    54 				        ;Exercise 2 — Factorial
    55 				        ;Calculate 5! = 5 × 4 × 3 × 2 × 1 = 120 and print it. 
    56 				        ;This needs nested loops — an outer loop for the multiplication count, and an 
    57 				        ;inner loop for the repeated addition that simulates each multiply.
    58
    59 				        ;additional zero page variable
    60 				        ;factorial       = $AA    ; the factorial of a number
    61
    62 203E A9 03 85 54		        mva #3 rowcrs                   ; set the cursor on row 3
    63 2042 A9 01 85 55		        mva #1 colcrs                   ; set the cursor on column 1
    64
    65 2046 A9 07 85 A7		        mva #7 cur_number               ; cur_number = starting number (try 6 or 7)
    66 204A A5 A7 85 AB		        mva cur_number cur_sum_lo       ; cur_sum_lo = cur_number
    67 204E A9 00 85 AC		        mva #0 cur_sum_hi               ; cur_sum_hi = 0 (cur_sum starts as a small number, fits in 8 bits)
    68
    69 2052 A5 A7		        lda cur_number
    70 2054 38			        sec
    71 2055 E9 01		        sbc #1
    72 2057 85 AF		        sta x_count                     ; x_count = cur_number - 1 (how many times to add)
    73
    74 2059			fact_loop:
    75 				        ; A_lo/A_hi = 0  (running total for this multiplication pass)
    76 2059 A9 00 85 AD		        mva #0 acc_lo
    77 205D A9 00 85 AE		        mva #0 acc_hi
    78 2061 A6 AF		        ldx x_count
    79
    80 2063			fact_inner:
    81 				        ; acc += cur_sum  (16-bit addition)
    82 2063 A5 AD		        lda acc_lo
    83 2065 18			        clc
    84 2066 65 AB		        adc cur_sum_lo
    85 2068 85 AD		        sta acc_lo
    86 206A A5 AE		        lda acc_hi
    87 206C 65 AC		        adc cur_sum_hi
    88 206E 85 AE		        sta acc_hi
    89
    90 2070 CA			        dex
    91 2071 D0 F0		        bne fact_inner
    92
    93 				        ; cur_sum = acc
    94 2073 A5 AD		        lda acc_lo
    95 2075 85 AB		        sta cur_sum_lo
    96 2077 A5 AE		        lda acc_hi
    97 2079 85 AC		        sta cur_sum_hi
    98
    99 207B C6 A7		        dec cur_number
   100 207D A5 A7		        lda cur_number
   101 207F C9 01		        cmp #1
   102 2081 F0 0A		        beq done_fact
   103
   104 				        ; x_count = cur_number - 1
   105 2083 A5 A7		        lda cur_number
   106 2085 38			        sec
   107 2086 E9 01		        sbc #1
   108 2088 85 AF		        sta x_count
   109
   110 208A 4C 59 20		        jmp fact_loop
   111 208D			done_fact:
   112
