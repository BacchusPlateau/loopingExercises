    12 				        ;Exercise 1 — Sum of squares
    13 				        ;Calculate 1² + 2² + 3² + 4² = 1 + 4 + 9 + 16 = 30 and print the result. 
    14 				        ;Remember no multiply instruction — you'll need repeated addition to square each number!
    15 				        
    16 				        ;important zero page variables:
    17 				        ;cur_sum         = $A6    ; current running sum of current number
    18 				        ;cur_number      = $A7    ; current number we're computing square of
    19 				        ;sum_of_squares  = $A9    ; the sum of squares from 1 to n
    20
    21 200D A9 04 85 A7		        mva #4 cur_number               ; cur_number = high_number
    22 2011 A9 00 85 A9		        mva #0 sum_of_squares           ; sum_of_squares = 0
    23 2015 A9 00		        lda #0                          ; a = 0
    24 2017 A6 A7		        ldx cur_number                  ; x = cur_number
    25
    26 2019			sum_of_squares_inner:
    27 2019 18			        clc                             ; clear carry
    28 201A 65 A7		        adc cur_number                  ; a += cur_number
    29 201C CA			        dex                             ; x--
    30 201D E0 00		        cpx #0                          ; x == 0?
    31 201F D0 F8		        bne sum_of_squares_inner        ; branch if we are > 0
    32
    33 2021 85 A6		        sta cur_sum                     ; cur_sum = a
    34 2023 A5 A9		        lda sum_of_squares              ; a = sum_of_squares
    35 2025 18			        clc                             ; clear carry
    36 2026 65 A6		        adc cur_sum                     ; a += cur_sum 
    37 2028 85 A9		        sta sum_of_squares              ; sum_of_squares = a
    38
    39 202A C6 A7		        dec cur_number                  ; cur_number--
    40 202C A5 A7		        lda cur_number                  ; a = cur_number
    41
    42 202E C9 00		        cmp #0                          ; a == 0?
    43 2030 F0 07		        beq done_sum                    ; if a==0, break out
    44
    45 2032 A9 00		        lda #0                          ; a = 0
    46 2034 A6 A7		        ldx cur_number                  ; x = cur_number
    47 				        
    48 2036 4C 19 20		        jmp sum_of_squares_inner        ; back to the top
    49 2039			done_sum:        
    50 2039 A5 A9		        lda sum_of_squares              ; a = sum_of_squares
    51 203B 20 5A 33		        jsr printDecimal        
    52
