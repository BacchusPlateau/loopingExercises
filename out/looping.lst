   189 				        ; plot point 8: (cx - circY, cy - circX)
   190 310A A5 9B		        lda cx
   191 310C 38			        sec
   192 310D E5 A0		        sbc circY
   193 310F 85 80		        sta plotX_lo
   194 3111 A5 9C		        lda cx_hi
   195 3113 E9 00		        sbc #0
   196 3115 85 81		        sta plotX_hi
   197 3117 A5 9D		        lda cy
   198 3119 38			        sec
   199 311A E5 9F		        sbc circX
   200 311C 85 82		        sta plotY
   201
   202 311E A5 80		        lda plotX_lo
   203 3120 48			        pha
   204 3121 A5 81		        lda plotX_hi
   205 3123 48			        pha
   206 3124 20 77 33		        jsr plotPoint
