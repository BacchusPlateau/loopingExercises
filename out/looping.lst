   534 				;=========================================================================================
   535 				; print a string
   536 				; Assumptions
   537 				; strptr_lo = low address of the string
   538 				; strptr_hi = high address of the string
   539 				;       together we have a 16-bit address of the string
   540
   541 				; Y = index of current character to process, starts at 0
   542 				; example calling code:
   543 				;       mva #1 csrhinh                  ; hide the cursor
   544 				;        mva #6 rowcrs                   ; set output row
   545 				;        mva #10 colcrs                  ; set output column
   546 				;        
   547 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   548 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   549 				;        jsr print_string                ; print the string
   550 				;
   551 				;========= don't forget you'll need data
   552 				;       .local string1
   553 				;        .byte 'HELLO FROM STRING ONE!',0
   554 				;        .endl
   555
   556 				;======================================================================
   557 327D			        .proc print_string
   558 327D A0 00		        ldy #0
   559 327F			loop:
   560 327F B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   561 3281 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   562 3283 F0 0D		        beq exit                        ; if true, branch to exit
   563 3285 98			        tya                             ; A = Y
   564 3286 48			        pha                             ; push A onto the stack
   565 3287 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   566 3289 20 96 32		        jsr putchar                     ; call putchar to write a character out
   567 328C 68			        pla                             ; A = pop stack
   568 328D A8			        tay                             ; Y = A
   569 328E C8			        iny                             ; Y = Y + 1
   570 328F 4C 7F 32		        jmp loop                        ; GOTO loop
   571 3292			exit:
   572 3292 60			        rts                             ; exit subroutine
   573 				        .endp
   574
   575 3293			stop:
   576 3293 4C 93 32		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   577 				;======================================================================
   578
   579 				; print a character
   580 				; Assumptions
   581 				; 1. the character is in register A
   582 				; 2. the character has been converted to ATASCII
   583 				; 3. before calling, save values of X and Y registers
   584
   585 3296			        .proc putchar
   586 3296 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   587 3297 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   588 329A 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   589 329B AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   590 329E 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   591 329F 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   592 32A0 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   593 				        .endp           ; end of putchar procedure
   594
   595 				;========================================================================================
   596 				;       print a 16-bit decimal
   597 				;       ON ENTRY: p16_val_lo/p16_val_hi contains the value to print
   598
   599 32A1			        .proc printBigDecimal
   600
   601 				        ; Ten thousands place
   602 32A1 A9 00 85 A5		        mva #0 p16_digit
   603
   604 32A5			tenthousands:
   605 				        ; is p16_val >= 10000?
   606 32A5 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   607 32A7 C9 27		        cmp #$27                ; 10,000 base 10 is $2710, that's why we're comparing $27 here, the hi byte
   608 32A9 90 1A		        bcc doneTenThousands    ; < 10000, done
   609 32AB D0 06		        bne do_subTenThousands  ; > 10000, subtract
   610 32AD A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   611 32AF C9 10		        cmp #$10                ; now we're comparing the low byte of the literal $2710 hex value
   612 32B1 90 12		        bcc doneTenThousands    ; = exactly check low byte
   613
   614 32B3			do_subTenThousands:
   615 				        ; subtract 10000 (16-bit)
   616 32B3 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   617 32B5 38			        sec                     ; set the carry
   618 32B6 E9 10		        sbc #$10                ; A -= $10 (we are subtracting the low byte first. looks weird because it's a literal)
   619 32B8 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   620 32BA A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   621 32BC E9 27		        sbc #$27                ; A -= $27 (we are subtracting the high byte of $2710 or 10,000 base 10)
   622 32BE 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   623 32C0 E6 A5		        inc p16_digit           ; p16_digit++
   624 32C2 4C A5 32		        jmp tenthousands        ; keep going
   625
   626 32C5			doneTenThousands:
   627 				        ; print the digit
   628 32C5 A5 A5		        lda p16_digit
   629 32C7 18			        clc
   630 32C8 69 30		        adc #offset_to_char
   631 32CA 20 96 32		        jsr putchar
   632
   633 				        ; Thousands
   634 32CD A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   635 32D1			thousands:
   636 				        ; is p16_val >= 1000?
   637 32D1 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   638 32D3 C9 03		        cmp #$3                 ; 1000 base 10 is $03E8, that's why we're comparing $3 here, the hi byte
   639 32D5 90 1A		        bcc doneThousands       ; < 1000, done
   640 32D7 D0 06		        bne do_subThousands     ; > 1000, subtract
   641 32D9 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   642 32DB C9 E8		        cmp #$E8                ; now we're comparing the low byte of the literal $03E8 hex value
   643 32DD 90 12		        bcc doneThousands       ; = exactly check low byte
   644
   645 32DF			do_subThousands:
   646 				        ; subtract 1000 (16-bit)
   647 32DF A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   648 32E1 38			        sec                     ; set the carry
   649 32E2 E9 E8		        sbc #$E8                ; A -= $E8 (we are subtracting the low byte first. looks weird because it's a literal)
   650 32E4 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   651 32E6 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   652 32E8 E9 03		        sbc #$3                 ; A -= $3 (we are subtracting the high byte of $03E8 or 1000 base 10)
   653 32EA 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   654 32EC E6 A5		        inc p16_digit           ; p16_digit++
   655 32EE 4C D1 32		        jmp thousands           ; keep going
   656
   657 32F1			doneThousands:
   658 				        ; print the digit
   659 32F1 A5 A5		        lda p16_digit
   660 32F3 18			        clc
   661 32F4 69 30		        adc #offset_to_char
   662 32F6 20 96 32		        jsr putchar      
   663
   664
   665 				        ; Hundreds
   666 32F9 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   667 32FD			hundreds:
   668 				        ; is p16_val >= 100?
   669 32FD A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   670 32FF C9 00		        cmp #$0                
   671 3301 90 1A		        bcc doneHundreds     
   672 3303 D0 06		        bne do_subHundreds     
   673 3305 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   674 3307 C9 64		        cmp #$64              
   675 3309 90 12		        bcc doneHundreds        ; = exactly check low byte
   676
   677 330B			do_subHundreds:
   678 				        ; subtract 100 (16-bit)
   679 330B A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   680 330D 38			        sec                     ; set the carry
   681 330E E9 64		        sbc #$64                ;  (we are subtracting the low byte first. looks weird because it's a literal)
   682 3310 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   683 3312 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   684 3314 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
   685 3316 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   686 3318 E6 A5		        inc p16_digit           ; p16_digit++
   687 331A 4C FD 32		        jmp hundreds           ; keep going
   688
   689 331D			doneHundreds:
   690 				        ; print the digit
   691 331D A5 A5		        lda p16_digit
   692 331F 18			        clc
   693 3320 69 30		        adc #offset_to_char
   694 3322 20 96 32		        jsr putchar   
   695
   696 				        ; Tens
   697 3325 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   698 3329			tens:
   699 				        ; is p16_val >= 10?
   700 3329 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   701 332B C9 00		        cmp #$0                
   702 332D 90 1A		        bcc doneTens     
   703 332F D0 06		        bne do_subTens     
   704 3331 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   705 3333 C9 0A		        cmp #$0A              
   706 3335 90 12		        bcc doneTens        ; = exactly check low byte
   707
   708 3337			do_subTens:
   709 				        ; subtract 100 (16-bit)
   710 3337 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   711 3339 38			        sec                     ; set the carry
   712 333A E9 0A		        sbc #$0A                ;  (we are subtracting the low byte first. looks weird because it's a literal)
   713 333C 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   714 333E A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   715 3340 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
   716 3342 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   717 3344 E6 A5		        inc p16_digit           ; p16_digit++
   718 3346 4C 29 33		        jmp tens           ; keep going
   719
   720 3349			doneTens:
   721 				        ; print the digit
   722 3349 A5 A5		        lda p16_digit
   723 334B 18			        clc
   724 334C 69 30		        adc #offset_to_char
   725 334E 20 96 32		        jsr putchar
   726
   727 				        ; ones are whatever is left in p16_val_lo
   728 3351 A5 A3		        lda p16_val_lo
   729 3353 18			        clc
   730 3354 69 30		        adc #offset_to_char
   731 3356 20 96 32		        jsr putchar
   732
   733 3359 60			        rts
   734 				        .endp
   735
   736
   737 				;========================================================================================
   738 				        ; print both digits in base 10, from left to right
   739 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   740 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   741 				        ; Assumtions: A contains the hex value of the number to print
   742
   743 335A			        .proc printDecimal
   744 335A A2 00		        ldx #0
   745 335C			checkCount:
   746 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   747 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   748 335C C9 0A		        cmp #10             ; Does A = 10?
   749 335E 90 07		        bcc doneCounting    ; branch if carry is cleared
   750 3360 38			        sec                 ; set carry
   751 3361 E9 0A		        sbc #10             ; A = A - 10
   752 3363 E8			        inx                 ; X = X + 1
   753 3364 4C 5C 33		        jmp checkCount
   754
   755 3367			doneCounting:   
   756 3367 48			        pha                 ; push(A) (push A onto the stack)
   757 3368 8A			        txa                 ; A = X
   758 3369 18			        clc
   759 336A 69 30		        adc #offset_to_char
   760 336C 20 96 32		        jsr putchar
   761
   762 336F 68			        pla                 ; A = pop() (pop the next value off the stack)
   763 3370 18			        clc 
   764 3371 69 30		        adc #offset_to_char
   765 3373 20 96 32		        jsr putchar
   766 3376 60			        rts
   767 				        .endp
   768 				;==================================================================================================
   769
   770 				; plot a point (x,y)
   771 				; Step 1: Find which ROW we're on
   772 				;        plotY × 40 = how many bytes to skip to reach our row
   773 				;        (each row is 40 bytes wide)
   774 				;        2^3 + 2^2
   775 				; Step 2: Find which BYTE within that row
   776 				;        plotX ÷ 8 = which byte contains our pixel
   777 				;        (each byte holds 8 pixels)
   778 				;
   779 				; Step 3: Add them together
   780 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   781 				;
   782 				; Step 4: Add SAVMSC
   783 				;        SAVMSC + offset = actual address in memory of our byte
   784 				;
   785 				; Step 5: Find which BIT within that byte
   786 				;        7 - (plotX mod 8) = which bit is our pixel
   787 				;
   788 				; Step 6: Set that bit
   789 				;        read the byte
   790 				;        OR with our bit mask
   791 				;        write the byte back
   792 				;
   793 3377			        .proc plotPoint
   794
   795 				        ; see multiplyingYby40.txt for full breakdown with an example!
   796
   797 				        ; defeat attract mode on every plot
   798 3377 A9 00 85 4D		        mva #0    ATRACT
   799 337B A9 FF 85 4E		        mva #$FF  ATRMSK
   800
   801 				        ; Step 1: Find which ROW we're on
   802 337F A5 82		        lda plotY
   803 3381 85 83		        sta temp_lo         ; temp = plotY
   804 3383 A9 00		        lda #0
   805 3385 85 84		        sta temp_hi         ; high byte starts at 0
   806
   807 				        ; × 2
   808 3387 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   809 3389 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   810
   811 				        ; × 4
   812 338B 06 83		        asl temp_lo
   813 338D 26 84		        rol temp_hi
   814
   815 				        ; × 8  ← save this!
   816 338F 06 83		        asl temp_lo
   817 3391 26 84		        rol temp_hi
   818 3393 A5 83		        lda temp_lo
   819 3395 85 87		        sta save_lo
   820 3397 A5 84		        lda temp_hi
   821 3399 85 88		        sta save_hi
   822
   823 				        ; × 16
   824 339B 06 83		        asl temp_lo
   825 339D 26 84		        rol temp_hi
   826
   827 				        ; × 32
   828 339F 06 83		        asl temp_lo
   829 33A1 26 84		        rol temp_hi
   830
   831 33A3 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   832 33A5 18			        clc                 ; clear carry
   833 33A6 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   834 33A8 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   835
   836 33AA A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   837 33AC 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   838 33AE 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   839 				        ; we now have the offset to our target row in temp_lo and temp_hi
   840
   841 				        ; calculate which bit 
   842 33B0 A5 80		        lda plotX_lo
   843 33B2 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   844 33B4 85 89		        sta bitpos          ; save for Step 5
   845
   846 				        ; Step 2: find offset from start of row to our pixel
   847 				        ; plotX ÷ 8 using 16-bit right shift
   848 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   849 				        ; ON EXIT:  A contains column byte offset (0-39)
   850 33B6 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   851 33B8 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   852
   853 33BA 46 81		        lsr plotX_hi        ; shift again
   854 33BC 66 80		        ror plotX_lo
   855
   856 33BE 46 81		        lsr plotX_hi        ; shift again
   857 33C0 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   858
   859 				        ; Step 3: add results from step 1 and 2 together
   860 33C2 A5 83		        lda temp_lo
   861 33C4 18			        clc
   862 33C5 65 80		        adc plotX_lo
   863 33C7 85 83		        sta temp_lo
   864
   865 33C9 A5 84		        lda temp_hi
   866 33CB 69 00		        adc #0
   867 33CD 85 84		        sta temp_hi
   868 				        ; temp now contains total byte offset from SAVMSC
   869
   870 				        ; Step 4: Add SAVMSC Base Address
   871 33CF A5 83		        lda temp_lo
   872 33D1 18			        clc
   873 33D2 65 58		        adc SAVMSC
   874 33D4 85 85		        sta scrptr_lo
   875
   876 33D6 A5 84		        lda temp_hi
   877 33D8 65 59		        adc SAVMSC+1
   878 33DA 85 86		        sta scrptr_hi
   879
   880 				        ; Step 5: find which bit to turn on
   881 				        ; algo:  bit position = 7 - (plotX mod 8)
   882 				        ; Step 5: find which bit to turn on
   883 33DC A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   884 33DE A6 89		        ldx bitpos          ; X = number of times to shift right
   885 33E0 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   886 33E2			shift_loop:
   887 33E2 4A			        lsr                 ; shift A right one position
   888 33E3 CA			        dex                 ; X = X - 1
   889 33E4 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   890 33E6			done_shift:
   891 				                            ; A now contains our bit mask
   892
   893 				        ; Step 6: turn on our bit!!
   894 33E6 85 8A		        sta bitmask             ; save mask
   895 33E8 A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   896 33EA B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   897 33EC 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   898 33EE 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   899
   900 33F0 60			        rts
   901 				        .endp
